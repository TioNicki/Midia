
{
  "entities": {
    "MediaGroup": {
      "title": "MediaGroup",
      "type": "object",
      "description": "Represents a church or media organization (Tenant).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "inviteCode": { "type": "string", "description": "Unique code for members to join." },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "inviteCode", "ownerId"]
    },
    "AppUser": {
      "title": "AppUser",
      "type": "object",
      "description": "User with tenant scope.",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "externalAuthId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["moderator", "admin", "member"] },
        "status": { "type": "string", "enum": ["pending", "approved"] },
        "lastProfileUpdate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "groupId", "externalAuthId", "name", "email", "role", "status"]
    },
    "PraiseSong": {
      "title": "PraiseSong",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "lyrics": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "groupId", "title", "artist", "lyrics"]
    },
    "DutyRole": {
      "title": "DutyRole",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "groupId", "name"]
    },
    "DutyRoster": {
      "title": "DutyRoster",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "assignments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "userName": { "type": "string" },
              "roleId": { "type": "string" },
              "roleName": { "type": "string" },
              "status": { "type": "string", "enum": ["pending", "confirmed", "swap_requested"] }
            }
          }
        },
        "songIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "groupId", "date", "description"]
    },
    "SwapRequest": {
      "title": "SwapRequest",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "originalRosterId": { "type": "string" },
        "targetRosterId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      },
      "required": ["id", "groupId", "userId", "originalRosterId", "targetRosterId", "status"]
    }
  },
  "auth": { "providers": ["password"] },
  "firestore": {
    "/media_groups/{groupId}": { "schema": "#/backend/entities/MediaGroup", "description": "Tenants." },
    "/app_users/{appUserId}": { "schema": "#/backend/entities/AppUser", "description": "Scoped users." },
    "/praise_songs/{songId}": { "schema": "#/backend/entities/PraiseSong", "description": "Scoped songs." },
    "/duty_roles/{roleId}": { "schema": "#/backend/entities/DutyRole", "description": "Scoped roles." },
    "/duty_rosters/{rosterId}": { "schema": "#/backend/entities/DutyRoster", "description": "Scoped schedules." },
    "/swap_requests/{requestId}": { "schema": "#/backend/entities/SwapRequest", "description": "Scoped swaps." },
    "/important_dates/{dateId}": { "schema": "#/backend/entities/ImportantDate", "description": "Scoped events." },
    "/feedback/{feedbackId}": { "schema": "#/backend/entities/Feedback", "description": "Scoped feedback." }
  }
}
